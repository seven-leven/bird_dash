{
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite",
    "build": "deno run -A ./scripts/build.ts",
    "build:assets": "deno run -A ./script/buildAssets.ts",
    "build:vite": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve:dist": "deno run --allow-net --allow-read jsr:@std/http/file-server dist/",
    "check": "deno run -A ./script/BuildAssets.ts check",
    "check:verbose": "deno run -A ./script/BuildAssets.ts check",
    "clean": "rm -rf dist node_modules",
    "fix": "deno fmt",
    "update": "deno outdated --update",
    "lint": "deno lint",
    "format": "deno fmt"
  },

  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitThis": true
  },

  "lint": {
    "exclude": ["dist", "node_modules", "public/full", "public/thumb", "raw_png"]
  },

  "fmt": {
    "exclude": ["dist", "node_modules", "public/full", "public/thumb", "raw_png"],
    "singleQuote": true,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "proseWrap": "always"
  },

  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.6",
    "sharp": "npm:sharp@0.34.5",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^6.0.5",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.2",
    "vite": "npm:vite@^8.0.3",
    "vue": "npm:vue@^3.5.31",
    "@vue/reactivity": "npm:@vue/reactivity@3.5.31",
    "@vue/runtime-core": "npm:@vue/runtime-core@3.5.31",
    "@vue/runtime-dom": "npm:@vue/runtime-dom@3.5.31",
    "@vue/compiler-dom": "npm:@vue/compiler-dom@3.5.31",
    "@vue/shared": "npm:@vue/shared@3.5.31"
  },

  "nodeModulesDir": "auto",

  "allowScripts": {
    "allow": ["npm:sharp@0.33.5"],
    "deny": ["npm:esbuild@0.27.2", "npm:sharp@0.34.5"]
  }
}
