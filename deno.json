{
  "importMap": "./import_map.json",
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-env --allow-run build.ts",
    "start": "deno run --allow-net --allow-read server.ts",
    "dev": "deno run --allow-net --allow-read --watch server.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test"
  }
}
